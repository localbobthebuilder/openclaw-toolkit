+import { describe, expect, it } from "vitest";
+import { buildSubagentSystemPrompt } from "./subagent-announce.js";
+
+describe("buildSubagentSystemPrompt", () => {
+  it("uses a compact tool-safe prompt for ollama-backed subagents", () => {
+    const prompt = buildSubagentSystemPrompt({
+      requesterSessionKey: "agent:main:main",
+      childSessionKey: "agent:coder-local:subagent:test",
+      task: "Create a file and stop.",
+      modelRef: "ollama/qwen3-coder:30b",
+      childDepth: 1,
+      maxSpawnDepth: 1,
+    });
+
+    expect(prompt).toContain("invoke the real tool call");
+    expect(prompt).not.toContain("## Output Format");
+    expect(prompt).not.toContain("## What You DON'T Do");
+  });
+
+  it("keeps the full prompt for hosted subagents", () => {
+    const prompt = buildSubagentSystemPrompt({
+      requesterSessionKey: "agent:main:main",
+      childSessionKey: "agent:coder-local:subagent:test",
+      task: "Create a file and stop.",
+      modelRef: "openai-codex/gpt-5.4",
+      childDepth: 1,
+      maxSpawnDepth: 1,
+    });
+
+    expect(prompt).toContain("## Output Format");
+    expect(prompt).toContain("## What You DON'T Do");
+  });
+});
