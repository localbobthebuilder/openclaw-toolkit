@@ -0,0 +1,131 @@
+import type { Model } from "@mariozechner/pi-ai";
+import { afterEach, beforeEach, describe, expect, it, vi } from "vitest";
+import { __testing as extraParamsTesting } from "./extra-params.js";
+import { runExtraParamsCase } from "./extra-params.test-support.js";
+
+vi.mock("@mariozechner/pi-ai", async () => {
+  const original =
+    await vi.importActual<typeof import("@mariozechner/pi-ai")>("@mariozechner/pi-ai");
+  return {
+    ...original,
+    streamSimple: vi.fn(() => ({
+      push: vi.fn(),
+      result: vi.fn(),
+    })),
+  };
+});
+
+beforeEach(() => {
+  extraParamsTesting.setProviderRuntimeDepsForTest({
+    prepareProviderExtraParams: ({ context }) => context.extraParams,
+    wrapProviderStreamFn: () => undefined,
+  });
+});
+
+afterEach(() => {
+  extraParamsTesting.resetProviderRuntimeDepsForTest();
+});
+
+describe("extra-params: tool choice", () => {
+  it("forwards configured toolChoice into stream options", () => {
+    const { options } = runExtraParamsCase({
+      cfg: {
+        agents: {
+          defaults: {
+            models: {
+              "ollama/qwen3-coder:30b": {
+                params: {
+                  toolChoice: "required",
+                },
+              },
+            },
+          },
+        },
+      } as never,
+      applyProvider: "ollama",
+      applyModelId: "qwen3-coder:30b",
+      model: {
+        api: "openai-completions",
+        provider: "ollama",
+        id: "qwen3-coder:30b",
+      } as unknown as Model<"openai-completions">,
+      payload: {
+        model: "qwen3-coder:30b",
+        messages: [],
+        stream: true,
+      },
+    });
+
+    expect((options as { toolChoice?: unknown } | undefined)?.toolChoice).toBe("required");
+  });
+
+  it("keeps configured toolChoice when caller options carry an unset toolChoice", () => {
+    const { options } = runExtraParamsCase({
+      cfg: {
+        agents: {
+          defaults: {
+            models: {
+              "ollama/qwen3-coder:30b": {
+                params: {
+                  toolChoice: "required",
+                },
+              },
+            },
+          },
+        },
+      } as never,
+      applyProvider: "ollama",
+      applyModelId: "qwen3-coder:30b",
+      model: {
+        api: "openai-completions",
+        provider: "ollama",
+        id: "qwen3-coder:30b",
+      } as unknown as Model<"openai-completions">,
+      options: {
+        toolChoice: undefined,
+      } as never,
+      payload: {
+        model: "qwen3-coder:30b",
+        messages: [],
+        stream: true,
+      },
+    });
+
+    expect((options as { toolChoice?: unknown } | undefined)?.toolChoice).toBe("required");
+  });
+
+  it("lets higher-precedence tool_choice override lower-precedence toolChoice", () => {
+    const { options } = runExtraParamsCase({
+      cfg: {
+        agents: {
+          defaults: {
+            params: {
+              toolChoice: "auto",
+            },
+            models: {
+              "ollama/qwen3-coder:30b": {
+                params: {
+                  tool_choice: "required",
+                },
+              },
+            },
+          },
+        },
+      } as never,
+      applyProvider: "ollama",
+      applyModelId: "qwen3-coder:30b",
+      model: {
+        api: "openai-completions",
+        provider: "ollama",
+        id: "qwen3-coder:30b",
+      } as unknown as Model<"openai-completions">,
+      payload: {
+        model: "qwen3-coder:30b",
+        messages: [],
+        stream: true,
+      },
+    });
+
+    expect((options as { toolChoice?: unknown } | undefined)?.toolChoice).toBe("required");
+  });
+});
