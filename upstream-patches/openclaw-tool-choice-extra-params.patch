+function normalizeSupportedToolChoice(value: unknown): SupportedToolChoice | undefined {
+  if (typeof value === "string") {
+    const normalized = value.trim().toLowerCase();
+    if (
+      normalized === "auto" ||
+      normalized === "none" ||
+      normalized === "any" ||
+      normalized === "required"
+    ) {
+      return normalized;
+    }
+    return undefined;
+  }
+  if (!value || typeof value !== "object" || Array.isArray(value)) {
+    return undefined;
+  }
+  const typeValue = (value as { type?: unknown }).type;
+  if (typeValue !== "function") {
+    return undefined;
+  }
+  const functionName = (value as { function?: { name?: unknown } }).function?.name;
+  if (typeof functionName !== "string" || functionName.trim().length === 0) {
+    return undefined;
+  }
+  return {
+    type: "function",
+    function: {
+      name: functionName.trim(),
+    },
+  };
+}
+
+function resolveSupportedToolChoice(
+  extraParams: Record<string, unknown>,
+): SupportedToolChoice | undefined {
+  const rawToolChoice =
+    extraParams.toolChoice !== undefined ? extraParams.toolChoice : extraParams.tool_choice;
+  const normalized = normalizeSupportedToolChoice(rawToolChoice);
+  if (rawToolChoice !== undefined && normalized === undefined) {
+    const toolChoiceSummary =
+      typeof rawToolChoice === "string" ? rawToolChoice : typeof rawToolChoice;
+    log.warn(`ignoring invalid toolChoice param: ${toolChoiceSummary}`);
+  }
+  return normalized;
+}
