+function summarizeToolChoiceValue(value: unknown): string | undefined {
+  if (typeof value === "string") {
+    const trimmed = value.trim().toLowerCase();
+    return trimmed.length > 0 ? trimmed : undefined;
+  }
+  if (!value || typeof value !== "object" || Array.isArray(value)) {
+    return undefined;
+  }
+  const typeValue = (value as { type?: unknown }).type;
+  if (typeof typeValue !== "string") {
+    return "object";
+  }
+  const normalizedTypeValue = typeValue.trim().toLowerCase();
+  if (normalizedTypeValue === "function") {
+    const functionName = (value as { function?: { name?: unknown } }).function?.name;
+    if (typeof functionName !== "string" || functionName.trim().length === 0) {
+      return "function";
+    }
+    return "function:" + functionName.trim();
+  }
+  if (normalizedTypeValue === "tool") {
+    const toolName = (value as { name?: unknown }).name;
+    if (typeof toolName !== "string" || toolName.trim().length === 0) {
+      return "tool";
+    }
+    return "tool:" + toolName.trim();
+  }
+  return normalizedTypeValue;
+}
