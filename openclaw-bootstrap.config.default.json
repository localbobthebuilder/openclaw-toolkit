{
  "repoUrl": "https://github.com/openclaw/openclaw.git",
  "repoCloneDepth": 1,
  "repoPath": "../openclaw",
  "composeFilePath": "../openclaw/docker-compose.yml",
  "envFilePath": "../openclaw/.env",
  "envTemplatePath": "openclaw.env.template",
  "dockerSetupScriptRelativePath": "scripts/docker/setup.sh",
  "gatewayPort": 18789,
  "bridgePort": 18790,
  "gatewayBind": "lan",
  "gatewayAuthRateLimit": {
    "maxAttempts": 10,
    "windowMs": 60000,
    "lockoutMs": 300000
  },
  "toolsets": {
    "list": [
      {
        "key": "minimal",
        "name": "Minimal",
        "allow": [
          "message"
        ],
        "deny": [
          "read",
          "write",
          "edit",
          "apply_patch",
          "exec",
          "process",
          "code_execution",
          "web_search",
          "web_fetch",
          "x_search",
          "memory_search",
          "memory_get",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "sessions_yield",
          "subagents",
          "session_status",
          "browser",
          "canvas",
          "agents_list",
          "update_plan",
          "image",
          "image_generate",
          "music_generate",
          "video_generate",
          "tts",
          "nodes",
          "cron",
          "gateway"
        ]
      }
    ]
  },
  "skills": {
    "enableAll": true
  },
  "contextManagement": {
    "compaction": {
      "mode": "safeguard",
      "timeoutSeconds": 900,
      "reserveTokensFloor": 24000,
      "identifierPolicy": "strict",
      "postCompactionSections": [
        "Session Startup",
        "Red Lines"
      ]
    },
    "contextPruning": {
      "mode": "cache-ttl",
      "ttl": "1h",
      "keepLastAssistants": 3,
      "softTrimRatio": 0.3,
      "hardClearRatio": 0.5,
      "minPrunableToolChars": 50000,
      "softTrim": {
        "maxChars": 4000,
        "headChars": 1500,
        "tailChars": 1500
      },
      "hardClear": {
        "enabled": true,
        "placeholder": "[Old tool result content cleared]"
      }
    }
  },
  "requireLocalhostPublishedPorts": true,
  "disableInsecureControlUiAuth": true,
  "clearRedundantDangerousNodeDenyCommands": true,
  "telegram": {
    "enabled": true,
    "defaultAccount": "default",
    "dmPolicy": "allowlist",
    "allowFrom": [],
    "groupAllowFrom": [],
    "execApprovals": {
      "enabled": true,
      "approvers": [],
      "target": "dm"
    },
    "groupPolicy": "allowlist",
    "groups": [
      {
        "enabled": true,
        "requireMention": false,
        "allowFrom": []
      }
    ],
    "accounts": []
  },
  "voiceNotes": {
    "enabled": true,
    "mode": "local-whisper",
    "gatewayImageTag": "openclaw:local-voice",
    "whisperModel": "base",
    "maxBytes": 20971520,
    "echoTranscript": false,
    "timeoutSeconds": 120
  },
  "tailscale": {
    "enableServe": true,
    "proxyTarget": "http://127.0.0.1:18789"
  },
  "watchdog": {
    "installScheduledTask": false,
    "everyMinutes": 5,
    "restartOnFailure": true,
    "alertOnFailure": true,
    "skipInternetCheck": false
  },
  "managedHooks": {
    "agentBootstrapOverlays": {
      "enabled": true,
      "overlayDirName": "bootstrap"
    }
  },
  "upstreamPatches": [
    {
      "enabled": true,
      "name": "local-subagent-tool-safe-prompts",
      "path": ".\\upstream-patches\\openclaw-local-subagent-tool-safe-prompts.patch",
      "managedPaths": [
        "src/agents/subagent-announce.ts",
        "src/agents/subagent-spawn.ts",
        "src/agents/subagent-announce.prompt.test.ts"
      ]
    }
  ],
  "ollama": {
    "enabled": true,
    "setAsDefaultModel": false,
    "clearFallbacks": true,
    "pullVramBudgetFraction": 0.7,
    "vramHeadroomMiB": 1536
  },
  "modelCatalog": [],
  "endpoints": [
    {
      "key": "local",
      "default": true,
      "telemetry": {
        "kind": "local-nvidia-smi"
      },
      "agents": [],
      "hostedModels": [],
      "ollama": {
        "enabled": true,
        "providerId": "ollama",
        "baseUrl": "http://host.docker.internal:11434",
        "hostBaseUrl": "http://127.0.0.1:11434",
        "apiKey": "ollama-local",
        "autoPullMissingModels": true,
        "models": []
      }
    }
  ],
  "sandbox": {
    "enabled": true,
    "dockerSocketSource": "/var/run/docker.sock.raw",
    "dockerSocketTarget": "/var/run/docker.sock",
    "dockerSocketGroup": "0",
    "buildGatewayImageWithDockerCli": true,
    "gatewayImageTag": "openclaw:local",
    "sandboxBaseImage": "openclaw-sandbox:bookworm-slim",
    "sandboxImage": "openclaw-sandbox-common:bookworm-slim",
    "mode": "all",
    "scope": "session",
    "workspaceAccess": "rw",
    "toolsFsWorkspaceOnly": true,
    "applyPatchWorkspaceOnly": true
  },
  "agents": {
    "telegramRouting": {
      "routes": []
    },
    "list": [
      {
        "id": "main",
        "name": "Main Agent",
        "enabled": true,
        "markdownTemplateKeys": {},
        "isMain": true,
        "default": true,
        "sandboxMode": "on",
        "subagents": {
          "enabled": true,
          "requireAgentId": true,
          "allowAgents": []
        },
        "candidateModelRefs": [],
        "allowLocalFallback": true,
        "toolsetKeys": []
      }
    ]
  },
  "workspaces": [],
  "verification": {
    "healthUrl": "http://127.0.0.1:18789/healthz",
    "reportPath": "bootstrap-report.txt"
  }
}
