  "envFilePath": "../openclaw/.env",
  "envTemplatePath": "openclaw.env.template",
  "dockerSetupScriptRelativePath": "scripts/docker/setup.sh",
  "gatewayPort": 18789,
  "bridgePort": 18790,
  "gatewayBind": "lan",
  "gatewayAuthRateLimit": {
    "maxAttempts": 10,
    "windowMs": 60000,
    "lockoutMs": 300000
  },
  "toolPolicy": {
    "globalProfile": "minimal",
    "globalAlsoAllow": [
      "read",
      "write",
      "edit",
      "apply_patch",
      "exec",
      "process",
      "sessions_list",
      "sessions_history",
      "sessions_send",
      "sessions_spawn",
      "sessions_yield",
      "subagents",
      "session_status",
      "memory_search",
      "memory_get"
    ],
    "globalDeny": [
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway"
    ],
    "researchAlsoAllow": [
      "read",
      "sessions_list",
      "sessions_history",
      "sessions_send",
      "sessions_spawn",
      "sessions_yield",
      "subagents",
      "session_status",
      "memory_search",
      "memory_get",
      "web_search",
      "web_fetch"
    ],
    "researchDeny": [
      "exec",
      "process",
      "write",
      "edit",
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway"
    ]
  },
  "skills": {
    "enableAll": true
  },
  "contextManagement": {
    "compaction": {
      "mode": "safeguard",
      "timeoutSeconds": 900,
      "reserveTokensFloor": 24000,
      "identifierPolicy": "strict",
      "postCompactionSections": [
        "Session Startup",
        "Red Lines"
      ]
    },
    "contextPruning": {
      "mode": "cache-ttl",
      "ttl": "1h",
      "keepLastAssistants": 3,
      "softTrimRatio": 0.3,
      "hardClearRatio": 0.5,
      "minPrunableToolChars": 50000,
      "softTrim": {
        "maxChars": 4000,
        "headChars": 1500,
        "tailChars": 1500
      },
      "hardClear": {
        "enabled": true,
        "placeholder": "[Old tool result content cleared]"
      }
    }
  },
  "requireLocalhostPublishedPorts": true,
  "disableInsecureControlUiAuth": true,
  "clearRedundantDangerousNodeDenyCommands": true,
  "telegram": {
    "enabled": true,
    "botToken": "",
    "tokenFile": "",
    "dmPolicy": "allowlist",
