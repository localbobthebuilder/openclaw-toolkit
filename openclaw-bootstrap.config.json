  "envFilePath": "../openclaw/.env",
  "envTemplatePath": "openclaw.env.template",
  "dockerSetupScriptRelativePath": "scripts/docker/setup.sh",
  "gatewayPort": 18789,
  "bridgePort": 18790,
  "gatewayBind": "lan",
  "gatewayAuthRateLimit": {
    "maxAttempts": 10,
    "windowMs": 60000,
    "lockoutMs": 300000
  },
  "toolsets": {
    "list": [
      {
        "key": "minimal",
        "name": "Minimal",
        "allow": [
          "message"
        ],
        "deny": [
          "read",
          "write",
          "edit",
          "apply_patch",
          "exec",
          "process",
          "code_execution",
          "web_search",
          "web_fetch",
          "x_search",
          "memory_search",
          "memory_get",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "sessions_yield",
          "subagents",
          "session_status",
          "browser",
          "canvas",
          "agents_list",
          "update_plan",
          "image",
          "image_generate",
          "music_generate",
          "video_generate",
          "tts",
          "nodes",
          "cron",
          "gateway"
        ]
      },
      {
        "key": "research",
        "name": "Research",
        "allow": [
          "read",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "sessions_yield",
          "subagents",
          "session_status",
          "memory_search",
          "memory_get",
          "web_search",
          "web_fetch"
        ],
        "deny": [
          "exec",
          "process",
          "write",
          "edit",
          "browser",
          "canvas",
          "nodes",
          "cron",
          "gateway"
        ]
      },
      {
        "key": "review",
        "name": "Review",
        "allow": [
          "read",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "session_status"
        ],
        "deny": [
          "exec",
          "write",
          "edit",
          "browser",
          "canvas",
          "nodes",
          "cron"
        ]
      },
      {
        "key": "codingDelegate",
        "name": "Coding Delegate",
        "allow": [
          "read",
          "write",
          "edit",
          "exec",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "sessions_yield",
          "subagents",
          "session_status",
          "code_execution",
          "process"
        ],
        "deny": [
          "browser",
          "canvas",
          "nodes",
          "cron"
        ]
      }
    ]
  },
  "skills": {
    "enableAll": true
  },
  "contextManagement": {
    "compaction": {
      "mode": "safeguard",
      "timeoutSeconds": 900,
      "reserveTokensFloor": 24000,
      "identifierPolicy": "strict",
      "postCompactionSections": [
        "Session Startup",
        "Red Lines"
      ]
    },
    "contextPruning": {
      "mode": "cache-ttl",
      "ttl": "1h",
      "keepLastAssistants": 3,
      "softTrimRatio": 0.3,
      "hardClearRatio": 0.5,
      "minPrunableToolChars": 50000,
      "softTrim": {
        "maxChars": 4000,
        "headChars": 1500,
        "tailChars": 1500
      },
      "hardClear": {
        "enabled": true,
        "placeholder": "[Old tool result content cleared]"
      }
    }
  },
  "requireLocalhostPublishedPorts": true,
  "disableInsecureControlUiAuth": true,
  "clearRedundantDangerousNodeDenyCommands": true,
  "telegram": {
    "enabled": true,
    "defaultAccount": "default",
    "dmPolicy": "allowlist",
    "allowFrom": [
      "8674459047"
    ],
    "groupAllowFrom": [],
    "execApprovals": {
      "enabled": true,
      "approvers": [
        "8674459047"
      ],
      "target": "dm"
    },
    "groupPolicy": "allowlist",
    "groups": [
      {
        "id": "-1003770800252",
        "enabled": true,
        "requireMention": false,
        "allowFrom": [
          "8674459047"
        ]
      }
    ],
    "accounts": []
  },
  "voiceNotes": {
    "enabled": true,
    "mode": "local-whisper",
    "gatewayImageTag": "openclaw:local-voice",
    "whisperModel": "base",
    "maxBytes": 20971520,
    "echoTranscript": false,
    "timeoutSeconds": 120
  },
  "tailscale": {
    "enableServe": true,
    "proxyTarget": "http://127.0.0.1:18789"
  },
  "watchdog": {
    "installScheduledTask": false,
    "everyMinutes": 5,
    "restartOnFailure": true,
    "alertOnFailure": true,
    "skipInternetCheck": false
  },
  "managedHooks": {
    "agentBootstrapOverlays": {
      "enabled": true,
      "overlayDirName": "bootstrap"
